# ─── Database ────────────────────────────────────────────────────────────────
# For local dev with SQLite:
DATABASE_URL="file:./db/dev.db"
# For production PostgreSQL:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/portfolio"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Contact Form — Resend (https://resend.com) ───────────────────────────────
# Sign up for free at resend.com, create an API key, verify your domain
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# The email address that receives contact form submissions (your inbox)
CONTACT_RECEIVER_EMAIL="you@yourdomain.com"

# The "from" address used when sending — must be a verified Resend domain
CONTACT_FROM_EMAIL="Portfolio Contact <noreply@yourdomain.com>"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
